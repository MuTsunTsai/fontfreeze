{
	"black-formatter.args": [
		"--line-length",
		"120"
	],
	"cSpell.ignoreRegExpList": [
		"/([\"'`])[a-z]{4}\\1/gi"
	],
	"cSpell.words": [
		"cmap",
		"emscripten",
		"fontfaces",
		"fontfreeze",
		"fonttools",
		"fvar",
		"glyf",
		"gsub",
		"gvar",
		"hhea",
		"hmtx",
		"onloadingdone",
		"Pyodide",
		"rsbuild",
		"unicodes",
		"vfit",
		"vuetify",
		"Webfont"
	],
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit"
	},
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.expand": false,
	"explorer.fileNesting.patterns": {
		"*.css": "$(capture).css.map",
		"*.js": "$(capture).prod.js, $(capture).min.js, $(capture).js.map",
		".gitignore": ".gitattributes",
		"Pipfile": "Pipfile.lock, pyproject.toml, .pylintrc",
		"README.md": "LICENSE.md, CONTRIBUTING.md",
		"eslint.config.js": ".editorconfig",
		"package.json": "pnpm-*.yaml, .npmrc, .browserslistrc"
	},
	"files.exclude": {
		"**/__pycache__/": true,
		"node_modules/": true,
		"patches/": true,
		".venv/": true
	},
	"python-envs.defaultEnvManager": "ms-python.python:pipenv",
	"python-envs.pythonProjects": []
}